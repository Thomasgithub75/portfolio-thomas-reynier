# ── Clé API Anthropic ──────────────────────────────────────────────────────────
# À ajouter dans Vercel > Settings > Environment Variables
# Ne jamais committer cette valeur — elle reste uniquement côté serveur
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Origins autorisées (sécurité API) ──────────────────────────────────────────
# Liste des domaines autorisés à appeler l'API, séparés par des virgules
# Sans cette variable, l'API bloque toutes les requêtes hors localhost
# Exemple : https://thomas-reynier.fr,https://portfolio-thomas-reynier.vercel.app
ALLOWED_ORIGINS=https://thomas-reynier.fr,https://portfolio-thomas-reynier.vercel.app

# ── Mots de passe des pages privées ────────────────────────────────────────────
# Accès à /lettre-motivation (défaut si absent : thomas2026)
VITE_LETTER_PASSWORD=ton_mot_de_passe

# Accès à /design-system (défaut si absent : thomas2026)
VITE_DS_PASSWORD=ton_mot_de_passe
