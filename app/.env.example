# Clé API Anthropic — à ajouter dans Vercel > Settings > Environment Variables
ANTHROPIC_API_KEY=sk-ant-xxxx

# Mot de passe pour accéder à /lettre-motivation (optionnel — défaut: thomas2026)
VITE_LETTER_PASSWORD=ton_mot_de_passe

# Secret partagé front/API pour protéger l'endpoint contre les appels directs
# Mettre la MÊME valeur dans VITE_LETTER_SECRET et LETTER_SECRET sur Vercel
VITE_LETTER_SECRET=un_secret_long_et_random
LETTER_SECRET=un_secret_long_et_random
